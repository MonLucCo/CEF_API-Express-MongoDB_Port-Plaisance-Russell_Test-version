                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/catways",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "catways"
                            ]
                        }
                    }
                },
                {
                    "name": "02-Create",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"catwayNumber\": 50,\n  \"type\": \"short\",\n  \"catwayState\": \"Bien pour le test\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/catways",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "catways"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "pm.collectionVariables.set(\"catwayId\", json._id);",
                                    "pm.test(\"catwayId créé\", () => pm.expect(json._id).to.exist);"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "03-Delete",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/catways/{{catwayId}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "catways",
                                "{{catwayId}}"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "03-Reservations",
            "item": [
                {
                    "name": "01-List",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/catways/{{catwayForReservation}}/reservations",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "catways",
                                "{{catwayForReservation}}",
                                "reservations"
                            ]
                        }
                    }
                },
                {
                    "name": "02-Create",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"checkIn\": \"2026-04-01\",\n  \"checkOut\": \"2026-04-05\",\n  \"clientName\": \"John Doe\",\n  \"boatName\": \"TestBoat\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/catways/{{catwayForReservation}}/reservations",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "catways",
                                "{{catwayForReservation}}",
                                "reservations"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "pm.collectionVariables.set(\"reservationId\", json._id);",
                                    "pm.test(\"reservationId créé\", () => pm.expect(json._id).to.exist);"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "03-Delete",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/catways/{{catwayForReservation}}/reservations/{{reservationId}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "catways",
                                "{{catwayForReservation}}",
                                "reservations",
                                "{{reservationId}}"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}