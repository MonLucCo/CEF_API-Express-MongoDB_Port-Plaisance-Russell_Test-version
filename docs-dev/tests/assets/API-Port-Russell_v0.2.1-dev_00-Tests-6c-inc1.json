                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"TestUser_PreDeploy\",\n  \"email\": \"test_predeploy@example.com\",\n  \"password\": \"1234\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "let json = pm.response.json();",
                                    "if (json.user) pm.collectionVariables.set(\"user_id\", json.user._id);"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "DELETE /auth/delete/:id (temporaire)",
