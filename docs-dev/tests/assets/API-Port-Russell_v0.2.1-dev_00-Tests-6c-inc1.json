                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/{{base_api}}/auth/register",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "{{base_api}}",
                                "auth",
                                "delete",
                                "{{user_id}}"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) pm.collectionVariables.set(\"user_id\", \"\");"
                                ]
                            }
                        }
                    ]
                }
