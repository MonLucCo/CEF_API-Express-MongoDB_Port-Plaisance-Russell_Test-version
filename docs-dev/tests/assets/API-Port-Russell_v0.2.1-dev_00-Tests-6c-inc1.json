                {
                    "name": "POST /auth/login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/{{base_api}}/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "{{base_api}}",
                                "auth",
                                "login"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"1234\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "let json = pm.response.json();",
                                    "if (json.token) pm.collectionVariables.set(\"token\", json.token);"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "POST /auth/register (temporaire)",
                    "request": {
                        "method": "POST",
