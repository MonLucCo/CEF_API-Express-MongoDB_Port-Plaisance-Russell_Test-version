{
    "info": {
        "name": "Port Plaisance Russell – E2E (local)",
        "_postman_id": "c1a3d1f0-1234-4bcd-9f11-abcdef123456",
        "description": "Tests E2E simulés pour l’API locale (issue‑17)",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "01 – Register",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "url": {
                    "raw": "http://localhost:3000/auth/register",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "3000",
                    "path": [
                        "auth",
                        "register"
                    ]
                },
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"TestUser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"1234\"\n}"
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "var json = pm.response.json();",
                            "pm.collectionVariables.set(\"userId\", json.user._id);"
                        ]
                    }
                }
            ]
        },
        {
            "name": "02 – Login",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "url": {
                    "raw": "http://localhost:3000/auth/login",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "3000",
                    "path": [
                        "auth",
                        "login"
                    ]
                },
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"1234\"\n}"
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "var json = pm.response.json();",
                            "pm.collectionVariables.set(\"token\", json.token);"
                        ]
                    }
                }
            ]
        },
        {
            "name": "03 – Delete User",
            "request": {
                "method": "DELETE",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "http://localhost:3000/auth/delete/{{userId}}",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "3000",
                    "path": [
                        "auth",
                        "delete",
                        "{{userId}}"
                    ]
                }
            }
        }
    ],
    "variable": [
        {
            "key": "token",
            "value": ""
        },
        {
            "key": "userId",
            "value": ""
        }
    ]
}