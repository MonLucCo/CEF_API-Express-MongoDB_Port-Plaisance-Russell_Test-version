{
  "name": "cef_api-express-mongodb_port-plaisance-russell_test-version",
  "version": "0.2.1",
  "description": "Etablissement d'une API avec Node.js/Express et MongoDB d'une \"gestion des réservations de catway\" (petit appontement de bateau du port de plaisance Russell) selon les spécifications du CEF.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "docs": "jsdoc -c config/dev/jsdoc.json",
    "docs:publish": "rm -rf public/docs && cp -r docs public/docs",
    "docs:predeploy": "npm run docs && npm run docs:publish",
    "clean": "node scripts/clean.js",
    "reinstall": "node scripts/reinstall.js",
    "validate:predeploy": "node scripts/validate-predeploy.js",
    "verify:deploy": "node ./scripts/verify-deploy.js",
    "test": "npm run tests:models && npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "mocha --require tests/root-hooks.js tests/controllers/**/*.test.js tests/middlewares/**/*.test.js --exit",
    "test:controllers": "mocha --require tests/root-hooks.js tests/controllers/**/*.test.js --exit",
    "test:integration": "mocha --require tests/root-hooks.js tests/integration/**/*.test.js --exit",
    "test:e2e": "echo \"Tests E2E non automatiques : utiliser Postman avec l’API locale (test-app.js) ou l’API Alwaysdata. Voir docs-dev/tests/03-niveau-3-e2e.md.\" && exit 0",
    "test:app": "node tests/test-app.js",
    "test:app:watch": "nodemon --config ./config/dev/nodemon.json tests/test-app.js",
    "tests": "npm run tests:models && npm run tests:frontend && npm run tests:api && npm run tests:client",
    "tests:models": "mocha --require tests/root-hooks.js tests/models/**/*.test.js --exit",
    "tests:models:unitaires": "mocha --require tests/root-hooks.js tests/models/**/*.unitaires.test.js --exit",
    "tests:models:integration": "mocha --require tests/root-hooks.js tests/models/**/*.integration.test.js --exit",
    "tests:models:catway": "mocha --require tests/root-hooks.js tests/models/**/catway*.test.js --exit",
    "tests:models:reservation": "mocha --require tests/root-hooks.js tests/models/**/reservation*.test.js --exit",
    "tests:models:user": "mocha --require tests/root-hooks.js tests/models/**/user*.test.js --exit",
    "tests:frontend": "echo \"Tests frontend non automatisés : utiliser les tests manuels avec l’API locale (test-app.js) ou l’API déployée. Voir docs-dev/tests/03-niveau-3-e2e.md.\" && exit 0",
    "tests:api": "echo \"Tests API non automatiques : utiliser les tests manuels avec l’API locale (test-app.js) ou l’API Alwaysdata. Voir docs-dev/tests/03-niveau-3-e2e.md.\" && exit 0",
    "tests:client": "echo \"Tests client non automatiques : utiliser les tests manuels avec l’API locale (test-app.js) ou l’API Alwaysdata. Voir docs-dev/tests/03-niveau-3-e2e.md.\" && exit 0",
    "start": "node src/server.js",
    "dev": "nodemon --config ./config/dev/nodemon.json src/server.js",
    "deploy": "bash ./scripts/deploy.sh",
    "deploy:dry": "bash ./scripts/deploy.sh --dry-run",
    "deploy:check": "bash ./scripts/deploy.sh --check",
    "deploy:preview": "bash ./scripts/deploy.sh --sync-preview",
    "deploy:help": "bash ./scripts/deploy.sh --help",
    "ssh:connect": "bash ./scripts/ssh-connect.sh",
    "ssh:site": "bash ./scripts/ssh-site-path.sh",
    "check:wsl": "node ./scripts/check-wsl-env.js",
    "check:local": "bash ./scripts/deploy-checklist-local.sh",
    "check:site": "bash ./scripts/deploy-checklist-site.sh",
    "import:data": "node scripts/import-data.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MonLucCo/CEF_API-Express-MongoDB_Port-Plaisance-Russell_Test-version.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/MonLucCo/CEF_API-Express-MongoDB_Port-Plaisance-Russell_Test-version/issues"
  },
  "homepage": "https://github.com/MonLucCo/CEF_API-Express-MongoDB_Port-Plaisance-Russell_Test-version#readme",
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.5"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "jsdoc": "^4.0.5",
    "mocha": "^11.7.5",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "sinon": "^7.5.0",
    "supertest": "^7.2.2"
  }
}