<!DOCTYPE html>
<html lang="fr">

<head>
    <%- include('partials/head', { title: "Liste des catways" }) %>
</head>

<body>

    <%- include('partials/header', { authenticated: true }) %>

        <main class="container">
            <h1>Liste des catways</h1>

            <div class="table-wrapper">

                <!-- Header fixe -->
                <table class="table-header">
                    <colgroup>
                        <col style="width: 35%">
                        <col style="width: 15%">
                        <col style="width: 15%">
                        <col style="width: 30%">
                    </colgroup>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Numéro</th>
                            <th>Type</th>
                            <th>État</th>
                        </tr>
                    </thead>
                </table>

                <!-- Body scrollable -->
                <div class="table-body-wrapper">
                    <table class="table-body">
                        <colgroup>
                            <col style="width: 35%">
                            <col style="width: 15%">
                            <col style="width: 15%">
                            <col style="width: 30%">
                        </colgroup>
                        <tbody>
                            <% catways.forEach(c=> { %>
                                <tr>
                                    <td>
                                        <%= c._id %>
                                    </td>
                                    <td>
                                        <%= c.catwayNumber %>
                                    </td>
                                    <td>
                                        <%= c.type %>
                                    </td>
                                    <td>
                                        <%= c.catwayState %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>

            </div>

            <a href="<%= BASE_URL %>/dashboard" class="btn-back">← Retour au dashboard</a>
        </main>

        <%- include('partials/footer', { version: version_tag }) %>

</body>

</html>