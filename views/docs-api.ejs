<!DOCTYPE html>
<html lang="fr">

<head>
    <%- include('partials/head', { title: "Documentation API" }) %>
</head>

<body>
    <%- include('partials/header', { authenticated: true }) %>

        <main class="container">
            <h1>Documentation API</h1>
            <p class="subtitle">Version JSDoc : <%= jsdoc_version %>
            </p>

            <section class="doc-section">
                <p>
                    La documentation technique de l’API est générée automatiquement via JSDoc.
                    Elle correspond à la version <strong>
                        <%= jsdoc_version %>
                    </strong> du projet.
                </p>

                <p>
                    Vous pouvez consulter la documentation complète ici :
                </p>

                <p>
                    <a href="<%= BASE_URL %>/docs/index.html" target="_blank" class="btn btn-primary">
                        Ouvrir la documentation JSDoc
                    </a>
                </p>

                <hr>

                <h2>Documentation intégrée</h2>
                <p>Vous pouvez consulter la documentation <strong>
                        <%= jsdoc_version %>
                    </strong> directement dans cette page :</p>

                <div style="border: 1px solid #ccc; height: 80vh; overflow: hidden; border-radius: 6px;">
                    <iframe src="<%= BASE_URL %>/docs/index.html" style="width: 100%; height: 80vh; border: none;"
                        title="Documentation JSDoc intégrée">
                    </iframe>
                </div>

            </section>
        </main>

        <%- include('partials/footer', { version: version_tag }) %>
</body>

</html>